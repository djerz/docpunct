#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
FEATURES_DIR="${DOCPUNCT_FEATURES_DIR:-$ROOT_DIR/features}"
CACHE_DIR="${DOCPUNCT_CACHE_DIR:-$HOME/.cache/docpunct}"
STATE_DIR="$CACHE_DIR/state"
INSTALLED_DIR="$STATE_DIR/installed"
LOG_DIR="$CACHE_DIR/log"
SRC_DIR="$CACHE_DIR/src"
BACKUP_DIR="$CACHE_DIR/backups/dotfiles"

export DOCPUNCT_ROOT="$ROOT_DIR"
export DOCPUNCT_FEATURES_DIR="$FEATURES_DIR"
export DOCPUNCT_CACHE_DIR="$CACHE_DIR"
export DOCPUNCT_STATE_DIR="$STATE_DIR"
export DOCPUNCT_INSTALLED_DIR="$INSTALLED_DIR"
export DOCPUNCT_LOG_DIR="$LOG_DIR"
export DOCPUNCT_SRC_DIR="$SRC_DIR"
export DOCPUNCT_DOTFILES_BACKUP_DIR="$BACKUP_DIR"

usage() {
  cat <<'EOF'
Usage:
  docpunct install FEATURE...
  docpunct update FEATURE...
  docpunct remove FEATURE...
  docpunct status
  docpunct list
  docpunct relink
  docpunct bootstrap
  docpunct shellcheck
  docpunct test-smoke
  docpunct test-container [22.04|24.04|26.04]
  docpunct test-containers
  docpunct test-devcontainer-cli-feature [22.04|24.04|26.04]
  docpunct test-doublecmd-feature [22.04|24.04|26.04]
  docpunct test-github-copilot-cli-feature [22.04|24.04|26.04]
  docpunct test-openai-codex-cli-feature [22.04|24.04|26.04]
  docpunct test-obsidian-feature [22.04|24.04|26.04]
  docpunct test-docker-feature [22.04|24.04|26.04]
  docpunct test-neovide-feature [22.04|24.04|26.04]
  docpunct test
EOF
}

die() {
  printf 'docpunct: %s\n' "$*" >&2
  exit 1
}

ensure_dirs() {
  mkdir -p "$INSTALLED_DIR" "$LOG_DIR" "$SRC_DIR" "$BACKUP_DIR"
}

feature_dir() {
  printf '%s/%s\n' "$FEATURES_DIR" "$1"
}

manifest_path() {
  printf '%s/feature.yml\n' "$(feature_dir "$1")"
}

require_feature() {
  local feature="$1"
  [[ "$feature" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid feature name: $feature"
  [[ -d "$(feature_dir "$feature")" ]] || die "unknown feature: $feature"
  [[ -f "$(manifest_path "$feature")" ]] || die "missing feature.yml for: $feature"
  if grep -Eq '^[[:space:]]*name[[:space:]]*:' "$(manifest_path "$feature")"; then
    die "feature.yml must not contain a name field: $feature"
  fi
}

is_installed() {
  [[ -f "$INSTALLED_DIR/$1" ]]
}

mark_installed() {
  mkdir -p "$INSTALLED_DIR"
  {
    printf 'feature=%s\n' "$1"
    printf 'installed_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'root=%s\n' "$ROOT_DIR"
  } >"$INSTALLED_DIR/$1"
}

unmark_installed() {
  rm -f -- "$INSTALLED_DIR/$1"
}

feature_description() {
  local manifest
  manifest="$(manifest_path "$1")"
  awk '
    /^[[:space:]]*description[[:space:]]*:/ {
      sub(/^[[:space:]]*description[[:space:]]*:[[:space:]]*/, "")
      gsub(/^"|"$/, "")
      gsub(/^'\''|'\''$/, "")
      print
      exit
    }
  ' "$manifest"
}

feature_deps() {
  local manifest
  manifest="$(manifest_path "$1")"
  awk '
    /^[[:space:]]*depends[[:space:]]*:[[:space:]]*$/ { in_dep=1; next }
    /^[^[:space:]-]/ { in_dep=0 }
    in_dep && /^[[:space:]]*-[[:space:]]*/ {
      sub(/^[[:space:]]*-[[:space:]]*/, "")
      sub(/[[:space:]]+#.*$/, "")
      gsub(/^"|"$/, "")
      gsub(/^'\''|'\''$/, "")
      if ($0 != "") print
    }
  ' "$manifest"
}

detect_dependency_cycle() {
  local feature="$1" stack="${2:-}" dep cycle
  local deps=()
  require_feature "$feature"

  if [[ " $stack " == *" $feature "* ]]; then
    cycle="${stack# } $feature"
    die "dependency cycle detected: $cycle"
  fi

  mapfile -t deps < <(feature_deps "$feature")
  for dep in "${deps[@]}"; do
    [[ -n "$dep" ]] || continue
    detect_dependency_cycle "$dep" "$stack $feature"
  done
}

script_for() {
  local feature="$1" action="$2"
  printf '%s/%s.sh\n' "$(feature_dir "$feature")" "$action"
}

run_feature_script() {
  local action="$1" feature="$2" script log tmp
  script="$(script_for "$feature" "$action")"
  [[ -f "$script" ]] || return 0
  [[ -x "$script" ]] || die "$script exists but is not executable"

  log="$LOG_DIR/$(date +%Y%m%d-%H%M%S)-$action-$feature.log"
  tmp="$(mktemp)"

  export DOCPUNCT_FEATURE="$feature"
  export DOCPUNCT_FEATURE_DIR
  DOCPUNCT_FEATURE_DIR="$(feature_dir "$feature")"

  if "$script" >"$tmp" 2>&1; then
    rm -f -- "$tmp"
  else
    mv -- "$tmp" "$log"
    printf 'docpunct: %s %s failed; log: %s\n' "$action" "$feature" "$log" >&2
    return 1
  fi
}

install_feature() {
  local feature="$1" dep
  local deps=()
  require_feature "$feature"

  if is_installed "$feature"; then
    printf '%s already installed\n' "$feature"
    return 0
  fi

  mapfile -t deps < <(feature_deps "$feature")
  for dep in "${deps[@]}"; do
    [[ -n "$dep" ]] || continue
    install_feature "$dep"
  done

  printf 'Installing %s\n' "$feature"
  if ! run_feature_script install "$feature"; then
    printf 'Cleaning up failed install: %s\n' "$feature" >&2
    if ! run_feature_script remove "$feature"; then
      printf 'docpunct: cleanup after failed install also failed: %s\n' "$feature" >&2
    fi
    return 1
  fi
  mark_installed "$feature"
}

install_requested_feature() {
  local feature="$1"
  require_feature "$feature"
  if ! is_installed "$feature"; then
    detect_dependency_cycle "$feature"
  fi
  install_feature "$feature"
}

collect_update_dependencies() {
  local feature="$1" dep
  local deps=()

  mapfile -t deps < <(feature_deps "$feature")
  for dep in "${deps[@]}"; do
    [[ -n "$dep" ]] || continue
    collect_update_dependencies "$dep"
    if [[ -z "${UPDATE_DEP_SEEN[$dep]:-}" ]]; then
      UPDATE_DEPENDENCIES+=("$dep")
      UPDATE_DEP_SEEN["$dep"]=1
    fi
  done
}

print_update_dependency_guidance() {
  local feature="$1" dep
  local -a UPDATE_DEPENDENCIES=()
  local -A UPDATE_DEP_SEEN=()

  collect_update_dependencies "$feature"
  [[ "${#UPDATE_DEPENDENCIES[@]}" -gt 0 ]] || return 0

  printf 'Dependencies of %s may also need attention; they will not be changed automatically.\n' "$feature"
  printf 'Run these commands in dependency-first order as needed:\n'
  for dep in "${UPDATE_DEPENDENCIES[@]}"; do
    if is_installed "$dep"; then
      printf '  docpunct update %s\n' "$dep"
    else
      printf '  docpunct install %s\n' "$dep"
    fi
  done
}

update_feature() {
  local feature="$1"
  require_feature "$feature"
  if ! is_installed "$feature"; then
    die "not installed: $feature"
  fi

  print_update_dependency_guidance "$feature"
  printf 'Updating %s\n' "$feature"
  run_feature_script update "$feature"
}

installed_dependents() {
  local target="$1" installed dep
  [[ -d "$INSTALLED_DIR" ]] || return 0
  for installed in "$INSTALLED_DIR"/*; do
    [[ -f "$installed" ]] || continue
    installed="$(basename "$installed")"
    while IFS= read -r dep; do
      [[ "$dep" == "$target" ]] && printf '%s\n' "$installed"
    done < <(feature_deps "$installed")
  done
  return 0
}

remove_feature() {
  local feature="$1" blockers
  require_feature "$feature"
  if ! is_installed "$feature"; then
    printf '%s is not installed\n' "$feature"
    return 0
  fi

  blockers="$(installed_dependents "$feature" | sort -u | paste -sd ' ' -)"
  if [[ -n "$blockers" ]]; then
    die "cannot remove $feature; installed feature(s) depend on it: $blockers"
  fi

  printf 'Removing %s\n' "$feature"
  run_feature_script remove "$feature"
  unmark_installed "$feature"
}

list_features() {
  local dir feature desc
  for dir in "$FEATURES_DIR"/*; do
    [[ -d "$dir" ]] || continue
    feature="$(basename "$dir")"
    require_feature "$feature"
    desc="$(feature_description "$feature")"
    if [[ -n "$desc" ]]; then
      printf '%-22s %s\n' "$feature" "$desc"
    else
      printf '%s\n' "$feature"
    fi
  done | sort
}

status_features() {
  local dir feature marker
  for dir in "$FEATURES_DIR"/*; do
    [[ -d "$dir" ]] || continue
    feature="$(basename "$dir")"
    marker="$INSTALLED_DIR/$feature"
    if [[ -f "$marker" ]]; then
      printf 'installed    %s\n' "$feature"
    else
      printf 'available    %s\n' "$feature"
    fi
  done | sort
}

relink_dotfiles() {
  require_feature dotfiles
  run_feature_script install dotfiles
}

shellcheck_scripts() {
  docker run --rm -i \
    --pull=never \
    --name docpunct-shellcheck \
    -v "$ROOT_DIR:/usr/src:ro" \
    --workdir /usr/src \
    ghcr.io/djerz/shellcheck:latest \
    shellcheck bin/docpunct features/*/*.sh features/epel/epel \
      features/epel/msmtp-wrapper tests/*.sh tests/container/*.sh
}

run_smoke_tests() {
  "$ROOT_DIR/tests/smoke.sh"
}

run_container_tests() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run.sh" "$ubuntu_version"
}

run_all_container_tests() {
  run_container_tests 22.04
  run_container_tests 24.04
  run_container_tests 26.04
}

run_docker_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-docker-feature.sh" "$ubuntu_version"
}

run_devcontainer_cli_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-devcontainer-cli-feature.sh" "$ubuntu_version"
}

run_doublecmd_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-doublecmd-feature.sh" "$ubuntu_version"
}

run_github_copilot_cli_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-github-copilot-cli-feature.sh" "$ubuntu_version"
}

run_openai_codex_cli_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-openai-codex-cli-feature.sh" "$ubuntu_version"
}

run_obsidian_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-obsidian-feature.sh" "$ubuntu_version"
}

run_neovide_feature_test() {
  local ubuntu_version="${1:-24.04}"
  "$ROOT_DIR/tests/container/run-neovide-feature.sh" "$ubuntu_version"
}

run_default_tests() {
  shellcheck_scripts
  run_smoke_tests
}

main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] || { usage; exit 2; }
  shift || true
  ensure_dirs

  case "$cmd" in
    bootstrap)
      [[ "$#" -eq 0 ]] || die "bootstrap takes no arguments"
      install_requested_feature core
      ;;
    install)
      [[ "$#" -gt 0 ]] || die "install requires at least one feature"
      while [[ "$#" -gt 0 ]]; do install_requested_feature "$1"; shift; done
      ;;
    update)
      [[ "$#" -gt 0 ]] || die "update requires at least one feature"
      while [[ "$#" -gt 0 ]]; do detect_dependency_cycle "$1"; update_feature "$1"; shift; done
      ;;
    remove)
      [[ "$#" -gt 0 ]] || die "remove requires at least one feature"
      while [[ "$#" -gt 0 ]]; do remove_feature "$1"; shift; done
      ;;
    list)
      [[ "$#" -eq 0 ]] || die "list takes no arguments"
      list_features
      ;;
    status)
      [[ "$#" -eq 0 ]] || die "status takes no arguments"
      status_features
      ;;
    relink)
      [[ "$#" -eq 0 ]] || die "relink takes no arguments"
      relink_dotfiles
      ;;
    shellcheck)
      [[ "$#" -eq 0 ]] || die "shellcheck takes no arguments"
      shellcheck_scripts
      ;;
    test-smoke)
      [[ "$#" -eq 0 ]] || die "test-smoke takes no arguments"
      run_smoke_tests
      ;;
    test-container)
      [[ "$#" -le 1 ]] || die "test-container takes at most one Ubuntu version"
      run_container_tests "${1:-24.04}"
      ;;
    test-containers)
      [[ "$#" -eq 0 ]] || die "test-containers takes no arguments"
      run_all_container_tests
      ;;
    test-docker-feature)
      [[ "$#" -le 1 ]] || die "test-docker-feature takes at most one Ubuntu version"
      run_docker_feature_test "${1:-24.04}"
      ;;
    test-devcontainer-cli-feature)
      [[ "$#" -le 1 ]] || die "test-devcontainer-cli-feature takes at most one Ubuntu version"
      run_devcontainer_cli_feature_test "${1:-24.04}"
      ;;
    test-doublecmd-feature)
      [[ "$#" -le 1 ]] || die "test-doublecmd-feature takes at most one Ubuntu version"
      run_doublecmd_feature_test "${1:-24.04}"
      ;;
    test-github-copilot-cli-feature)
      [[ "$#" -le 1 ]] || die "test-github-copilot-cli-feature takes at most one Ubuntu version"
      run_github_copilot_cli_feature_test "${1:-24.04}"
      ;;
    test-openai-codex-cli-feature)
      [[ "$#" -le 1 ]] || die "test-openai-codex-cli-feature takes at most one Ubuntu version"
      run_openai_codex_cli_feature_test "${1:-24.04}"
      ;;
    test-obsidian-feature)
      [[ "$#" -le 1 ]] || die "test-obsidian-feature takes at most one Ubuntu version"
      run_obsidian_feature_test "${1:-24.04}"
      ;;
    test-neovide-feature)
      [[ "$#" -le 1 ]] || die "test-neovide-feature takes at most one Ubuntu version"
      run_neovide_feature_test "${1:-24.04}"
      ;;
    test)
      [[ "$#" -eq 0 ]] || die "test takes no arguments"
      run_default_tests
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
